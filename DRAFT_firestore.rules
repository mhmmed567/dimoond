rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isSignedIn() && getUserData().role == role;
    }

    function isAdmin() {
      return hasRole('admin');
    }

    function isStaff() {
      return hasRole('staff');
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Products ---
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
      
      function isValidProduct(data) {
        return data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
               data.nameEn is string && data.nameEn.size() > 0 && data.nameEn.size() <= 100 &&
               data.price is number && data.price >= 0 &&
               data.category in ['coffee', 'cold', 'dessert', 'extras'] &&
               data.available is bool;
      }
      
      allow create: if isAdmin() && isValidProduct(incoming()) && isValidId(productId);
      allow update: if isAdmin() && isValidProduct(incoming());
      allow delete: if isAdmin();
    }

    // --- Orders ---
    match /orders/{orderId} {
      allow list: if isSignedIn() && (isAdmin() || isStaff() || resource.data.userId == request.auth.uid);
      allow get: if isSignedIn() && (isAdmin() || isStaff() || resource.data.userId == request.auth.uid);
      
      function isValidOrder(data) {
        return data.items is list && data.items.size() > 0 &&
               data.total is number && data.total >= 0 &&
               data.status in ['pending', 'preparing', 'ready', 'delivered'] &&
               data.paymentMethod in ['cash', 'card'] &&
               data.createdAt is timestamp;
      }

      allow create: if isSignedIn() && isValidOrder(incoming()) && 
                    incoming().userId == request.auth.uid &&
                    incoming().status == 'pending' &&
                    incoming().createdAt == request.time;
                    
      allow update: if isSignedIn() && (
        // Staff/Admin can update status
        ((isAdmin() || isStaff()) && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt']) && 
         incoming().status in ['pending', 'preparing', 'ready', 'delivered'] &&
         incoming().updatedAt == request.time) ||
        // Admin can do anything
        (isAdmin() && isValidOrder(incoming()))
      );
      
      allow delete: if isAdmin();
    }

    // --- Settings ---
    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
      
      function isValidSettings(data) {
        return data.logoUrl is string && data.logoUrl.size() <= 1000 &&
               data.storeName is string && data.storeName.size() <= 100;
      }
      
      allow create, update: if isAdmin() && isValidSettings(incoming());
    }

    // --- Users ---
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      // Users can only be created/updated by admins or during registration (first time)
      // For this app, we'll allow an admin to set roles.
      // A special case for the first admin (using email from platform)
      function isFirstAdmin(email) {
        return email == 'mhmmed6142023@gmail.com'; 
      }

      allow create: if (isSignedIn() && request.auth.uid == userId && isFirstAdmin(request.auth.token.email)) || isAdmin();
      allow update: if isAdmin() || (isSignedIn() && request.auth.uid == userId && incoming().diff(existing()).affectedKeys().hasOnly(['email']) && incoming().email == request.auth.token.email);
    }
  }
}
